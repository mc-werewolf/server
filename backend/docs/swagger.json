{
    "swagger": "2.0",
    "info": {
        "description": "マイクラ人狼 専用バックエンドAPI",
        "title": "Werewolf Server API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api",
    "paths": {
        "/health": {
            "get": {
                "description": "APIサーバーの生存確認用エンドポイント",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "ヘルスチェック",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.healthResponse"
                        }
                    }
                }
            }
        },
        "/health/db": {
            "get": {
                "description": "PostgreSQLへの接続確認用エンドポイント",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "DB疎通確認",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.dbHealthResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.dbHealthResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.dbHealthResponse": {
            "type": "object",
            "properties": {
                "database": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "api.healthResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string"
                }
            }
        }
    }
}